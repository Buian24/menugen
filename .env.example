# Đổi tên file này thành .env trên server và điền các giá trị của bạn
# SECRET_KEY có thể tạo bằng lệnh: python3 -c 'import secrets; print(secrets.token_hex())'
SECRET_KEY='your_super_secret_key_for_production'

# Thông tin từ tài khoản PayOS của bạn
PAYOS_CLIENT_ID='your_payos_client_id'
PAYOS_API_KEY='your_payos_api_key'
PAYOS_CHECKSUM_KEY='your_payos_checksum_key'